    <title>Privacy Policy - Railway HRMS</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            line-height: 1.6;
            color: #333;
            max-width: 800px;
            margin: 0 auto;
            padding: 20px;
        }
        h1 { border-bottom: 2px solid #2c3e50; padding-bottom: 10px; color: #2c3e50; }
        h2 { color: #2980b9; margin-top: 25px; }
        h3 { color: #34495e; }
        p { margin-bottom: 15px; }
        ul { margin-bottom: 15px; }
